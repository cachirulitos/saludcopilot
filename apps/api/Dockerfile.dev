FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y gcc libpq-dev && rm -rf /var/lib/apt/lists/*

# Install rules_engine package first
COPY packages/rules_engine /tmp/rules_engine
RUN pip install --no-cache-dir /tmp/rules_engine && rm -rf /tmp/rules_engine

# Install API dependencies (filter out the editable rules_engine line)
COPY apps/api/requirements.txt .
RUN grep -v "rules_engine" requirements.txt > requirements_docker.txt \
    && pip install --no-cache-dir -r requirements_docker.txt \
    && rm requirements_docker.txt

COPY apps/api/ .
EXPOSE 8000
