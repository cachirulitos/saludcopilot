# ── Base de datos ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://saludcopilot:saludcopilot_dev@localhost:5432/saludcopilot_dev
POSTGRES_DB=saludcopilot_dev
POSTGRES_USER=saludcopilot
POSTGRES_PASSWORD=saludcopilot_dev

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Seguridad ─────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
SECRET_KEY=cambia-esto-en-produccion

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_PHONE_NUMBER=521XXXXXXXXXX
WHATSAPP_VERIFY_TOKEN=saludcopilot_verify

# ── LLM (Google Gemini) ───────────────────────────────────────────────────
LLM_API_KEY=

# ── Tokens internos entre servicios ──────────────────────────────────────
INTERNAL_BOT_TOKEN=saludcopilot-internal-token-change-in-prod
INTERNAL_API_TOKEN=saludcopilot-internal-token-change-in-prod

# ── Entorno ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug

# ── CV Worker ─────────────────────────────────────────────────────────────
INTERNAL_CV_TOKEN=saludcopilot-internal-token-change-in-prod
CAMERA_INDEX=0
CAPTURE_INTERVAL_SECONDS=5
YOLO_MODEL_NAME=yolov8m.pt
CONFIDENCE_THRESHOLD=0.8
# ROI en píxeles "x1,y1,x2,y2" — vacío = frame completo
# Medir sobre un frame congelado con VLC o similar
CAMERA_ROI=
# JSON: índice de cámara → UUID del área en la DB
# Rellenar con los UUIDs generados por scripts/seed.py
CAMERA_TO_AREA_MAPPING={"0":"<AREA_UUID>"}
